# Supabase-Umgebung (lokal / Vercel)
# Kopiere nach `.env.local` und trage deine Werte ein (Projekt: Settings → API).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: Migration 003 per `npm run db:apply-003` (URI mit DB-Passwort: Dashboard → Database → Connection string; nicht committen)
# DATABASE_URL=postgresql://postgres.[PROJECT]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
